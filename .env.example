# BBMW0 — AI provider keys.
# Set ANY of these in your hosting environment to light up that provider in the AI bar.
# At least one is needed for the real LLM features. Without keys, the editor falls
# back to a local heuristic (still works, just less smart).

# Anthropic Claude  — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o-mini)  — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini  — https://aistudio.google.com/apikey  (free tier available)
GOOGLE_GEMINI_API_KEY=

# Perplexity (Sonar)  — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Groq (hosts Llama 3 + others)  — https://console.groq.com/keys  (free tier available)
GROQ_API_KEY=
