{
  "name": "bbmw0-technologies-ai",
  "version": "0.2.0",
  "description": "Mobile-first, Shorts-native video editor built on Remotion. Touch-friendly, 9:16 by default, AI-assisted, 10 languages, 5-LLM consensus.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "render": "remotion render src/compositions/registry.tsx",
    "render:short": "remotion render src/compositions/registry.tsx Showcase out/short.mp4",
    "render:tutorial": "remotion render src/compositions/registry.tsx Tutorial out/tutorial.mp4",
    "render:battle": "remotion render src/compositions/registry.tsx Battle out/battle.mp4",
    "render:speedrun": "remotion render src/compositions/registry.tsx SpeedRun out/speedrun.mp4",
    "render:featuredrop": "remotion render src/compositions/registry.tsx FeatureDrop out/featuredrop.mp4",
    "render:longform": "remotion render src/compositions/registry.tsx LongForm out/longform.mp4",
    "render:all-shorts": "npm run render:short && npm run render:tutorial && npm run render:battle && npm run render:speedrun && npm run render:featuredrop"
  },
  "dependencies": {
    "@remotion/player": "4.0.454",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.454"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.454",
    "@remotion/eslint-config-flat": "4.0.454",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.3",
    "typescript": "5.6.3",
    "vite": "5.4.10"
  }
}
