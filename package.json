{
  "name": "bbmw0-technologies-ai",
  "version": "0.4.0",
  "description": "Mobile-first, Shorts-native video editor built on Remotion. Touch-friendly, 9:16 by default, AI-assisted, 10 languages, 5-LLM consensus, daily auto-publish to YouTube.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "render": "remotion render src/compositions/registry.tsx",
    "render:short": "remotion render src/compositions/registry.tsx Showcase out/short.mp4",
    "render:tutorial": "remotion render src/compositions/registry.tsx Tutorial out/tutorial.mp4",
    "render:battle": "remotion render src/compositions/registry.tsx Battle out/battle.mp4",
    "render:speedrun": "remotion render src/compositions/registry.tsx SpeedRun out/speedrun.mp4",
    "render:featuredrop": "remotion render src/compositions/registry.tsx FeatureDrop out/featuredrop.mp4",
    "render:consensus": "remotion render src/compositions/registry.tsx Consensus out/consensus.mp4",
    "render:phoneinstall": "remotion render src/compositions/registry.tsx PhoneInstall out/phoneinstall.mp4",
    "render:languages": "remotion render src/compositions/registry.tsx Languages out/languages.mp4",
    "render:presets": "remotion render src/compositions/registry.tsx Presets out/presets.mp4",
    "render:opensource": "remotion render src/compositions/registry.tsx OpenSource out/opensource.mp4",
    "render:mobilefirst": "remotion render src/compositions/registry.tsx MobileFirst out/mobilefirst.mp4",
    "render:whyvertical": "remotion render src/compositions/registry.tsx WhyVertical out/whyvertical.mp4",
    "render:yourpocket": "remotion render src/compositions/registry.tsx YourPocket out/yourpocket.mp4",
    "render:fromidea": "remotion render src/compositions/registry.tsx FromIdea out/fromidea.mp4",
    "render:longform": "remotion render src/compositions/registry.tsx LongForm out/longform.mp4",
    "render:all-themed": "npm run render:consensus && npm run render:phoneinstall && npm run render:languages && npm run render:presets && npm run render:opensource && npm run render:mobilefirst && npm run render:whyvertical && npm run render:yourpocket && npm run render:fromidea",
    "render:all-shorts": "npm run render:short && npm run render:tutorial && npm run render:battle && npm run render:speedrun && npm run render:featuredrop && npm run render:all-themed",
    "yt:auth": "node scripts/youtube-auth.mjs",
    "yt:upload": "node scripts/youtube-upload.mjs",
    "gen:daily": "node scripts/generate-shorts.mjs",
    "render:daily": "node scripts/render-batch.mjs",
    "publish:daily": "node scripts/render-batch.mjs --upload",
    "research:trends": "node scripts/research-trends.mjs",
    "print:secrets": "node scripts/print-secrets.mjs"
  },
  "dependencies": {
    "@remotion/player": "4.0.454",
    "googleapis": "^171.4.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.454"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.454",
    "@remotion/eslint-config-flat": "4.0.454",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.3",
    "typescript": "5.6.3",
    "vite": "5.4.10"
  }
}
